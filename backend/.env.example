# ── Database (Neon / any PostgreSQL) ──────────────────────────
PORT=4000
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=codereview_platform_secret_key_2024_xyz
JWT_EXPIRES_IN=7d

# ── GEMINI / ANTHROPIC ─────────────────────────────────────────────
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key

# ── GitHub (for PR-based reviews) ──────────────────────────────────
# Fine for local/dev: create a classic PAT with repo access.
GITHUB_TOKEN=ghp_...

# ── Server ────────────────────────────────────────────────────────
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
